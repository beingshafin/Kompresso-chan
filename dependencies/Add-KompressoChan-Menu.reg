"Icon"="C:\\Program Files\\Kompresso-chan\\menu\\mirror.ico"

[HKEY_CLASSES_ROOT\*\shell\KompressoUnified\shell\03mirror\command]
@="wscript.exe \"C:\\Program Files\\Kompresso-chan\\kompresso-quick-launch.vbs\" \"%1\" \"mirror\""

[HKEY_CLASSES_ROOT\*\shell\KompressoUnified\shell\04advanced]
@="Advanced..."
"Icon"="C:\\Program Files\\Kompresso-chan\\menu\\advanced.ico"

[HKEY_CLASSES_ROOT\*\shell\KompressoUnified\shell\04advanced\command]
@="wscript.exe \"C:\\Program Files\\Kompresso-chan\\kompresso-launch.vbs\" \"%1\""

