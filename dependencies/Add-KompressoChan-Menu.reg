Windows Registry Editor Version 5.00

; Unified Compress with Kompresso submenu - For files
[HKEY_CLASSES_ROOT\*\shell\KompressoUnified]
"MUIVerb"="Compress with Kompresso"
"SubCommands"=""
"Icon"="C:\\Program Files\\Kompresso-chan\\komchan.exe"

[HKEY_CLASSES_ROOT\*\shell\KompressoUnified\shell\01replace]
@="Quick Replace"
"Icon"="C:\\Program Files\\Kompresso-chan\\menu\\replace.ico"

[HKEY_CLASSES_ROOT\*\shell\KompressoUnified\shell\01replace\command]
@="wscript.exe \"C:\\Program Files\\Kompresso-chan\\kompresso-quick-launch.vbs\" \"%1\" \"replace\""

[HKEY_CLASSES_ROOT\*\shell\KompressoUnified\shell\02cascade]
@="Quick Cascade"
"Icon"="C:\\Program Files\\Kompresso-chan\\menu\\cascade.ico"

[HKEY_CLASSES_ROOT\*\shell\KompressoUnified\shell\02cascade\command]
@="wscript.exe \"C:\\Program Files\\Kompresso-chan\\kompresso-quick-launch.vbs\" \"%1\" \"cascade\""

[HKEY_CLASSES_ROOT\*\shell\KompressoUnified\shell\03mirror]
